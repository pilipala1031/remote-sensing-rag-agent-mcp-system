SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-m3

LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=your_openai_compatible_base_url
LLM_MODEL=GLM-5.1

CHROMA_PERSIST_DIR=./data/chroma
RAW_DATA_DIR=./data/raw
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=5
SIMILARITY_THRESHOLD=0.3

# Agent Evidence Verification（是否启用证据校验）
ENABLE_AGENT_VERIFICATION=true

# Agent Verification 模式（off / sync / deferred）
# off: 不执行证据校验
# sync: 在 /api/agent/query 中同步执行证据校验
# deferred: /api/agent/query 先返回回答，前端再调用 /api/agent/verify
AGENT_VERIFICATION_MODE=deferred

# Agent Verification 轻量化级别（lightweight / full）
# lightweight: 裁剪 answer/sources/tool_calls 后校验
# full: 相对完整校验，但也做基本截断
AGENT_VERIFICATION_LEVEL=lightweight

# Verification 独立模型配置（留空则复用主 LLM_MODEL）
VERIFICATION_MODEL=
VERIFICATION_MAX_TOKENS=512
VERIFICATION_TEMPERATURE=0

# Agent 回答长度控制（ChatOpenAI max_tokens，0 或负数表示不传）
AGENT_MAX_TOKENS=1000

# Agent LLM 响应缓存（InMemoryCache，仅对 Agent 路径 ChatOpenAI 生效）
# true: 相同问题第二次直接返回缓存结果，不调用 LLM API
# false: 每次都真实调用 LLM
# 前端可通过请求体 enable_cache 字段逐请求覆盖此配置
ENABLE_AGENT_CACHE=false

# Agent 响应级缓存（Response Cache，在 AgentService.query 层缓存完整响应）
# true: 相同问题+相同配置第二次直接返回缓存结果，零 LLM/工具调用
# false: 不缓存（默认）
# 文档入库/删除时自动清空，不会返回过期回答
ENABLE_AGENT_RESPONSE_CACHE=false
AGENT_RESPONSE_CACHE_TTL_SECONDS=600
AGENT_RESPONSE_CACHE_MAX_SIZE=100

# Rerank（Cross-encoder 重排序，消融实验最佳配置 rerank_k10）
# 开启后先向量检索 candidate_k 条，经 cross-encoder 精排后保留 top_k 条
# 复用 SILICONFLOW_API_KEY / SILICONFLOW_BASE_URL，无需额外配置密钥
USE_RERANK=true
RERANK_CANDIDATE_K=10
RERANK_MODEL=BAAI/bge-reranker-v2-m3


# ============================================================
# 前端 / 演示相关（可选）
# ============================================================

# Frontend -> Backend API base URL
# 不同场景取值不同：
#   - 本地裸跑（streamlit run + uvicorn 各自启动）：
#       RAG_API_BASE=http://127.0.0.1:8000
#   - Docker Compose 启动：
#       RAG_API_BASE=http://backend:8000
#       （docker-compose.yml 已通过 environment 显式设置此项，
#        会覆盖本文件中的默认值，无需手动修改）
#   - Cloudflare Tunnel 公网演示：
#       RAG_API_BASE=http://backend:8000
#       （注意：tunnel 暴露的是前端 8501，不是后端 8000；
#        不要把此项改为 trycloudflare.com 地址，也不要改成 /api 相对路径）
RAG_API_BASE=http://127.0.0.1:8000

# Optional demo access password for Streamlit UI.
# If empty or unset, password gate is disabled (本地开发不受影响)。
# If set, users must enter this password before accessing the UI.
# 仅用于 Cloudflare Tunnel 等临时公网演示场景，不是生产级鉴权方案。
DEMO_PASSWORD=


